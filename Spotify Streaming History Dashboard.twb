    <worksheet name='Heat Map'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontname='Avenir' fontsize='14'>Daily Listening Activity</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='fact_streams+' name='federated.1vilpfd16zit53124pxzk11bh6fh' />
          </datasources>
          <datasource-dependencies datasource='federated.1vilpfd16zit53124pxzk11bh6fh'>
            <column caption='Daily Minutes Listened' datatype='real' name='[Calculation_5168965463846917]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ &#10;    FIXED [full_date], [day_name], [time_of_day] :&#10;    SUM([minutes_played])&#10;}' />
            </column>
            <column caption='Album Name' datatype='string' name='[album_name]' role='dimension' type='nominal' />
            <column caption='Artist Name' datatype='string' name='[artist_name]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_5168965463846917]' derivation='Avg' name='[avg:Calculation_5168965463846917:qk]' pivot='key' type='quantitative' />
            <column caption='Country' datatype='string' name='[country_name]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
